# Site origin (used by metadataBase, OG tags, and structured data)
NEXT_PUBLIC_SERVER_URL=https://www.alassalijewelry.com

# --- Google Places API: live Google Business Profile reviews ---
# Powers components/reviews/LiveReviewsStrip.tsx
#
# Setup:
#   1. Google Cloud Console → create or select a project
#   2. Enable "Places API" on that project
#   3. APIs & Services → Credentials → Create API key
#   4. Restrict the key to "Places API" (and ideally to Vercel IPs / referrers)
#   5. Paste below and redeploy
#
# The Place ID is already stored in lib/seo/siteConfig.ts (googleMapsPlaceId)
# so you only need to provide the key.
GOOGLE_PLACES_API_KEY=

# (Other env vars used elsewhere in the app — keep existing values)
# DATABASE_URL=
# PAYLOAD_SECRET=
# DATOCMS_API_TOKEN=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# --- Resend: transactional email for inquiry notifications ---
# Powers app/api/inquiries/route.ts
# Sends inquiry notifications to contact@alasalicustomjewelry.ca
# and auto-confirmations to customers.
#
# Setup:
#   1. resend.com → API Keys → Create API Key (Sending access)
#   2. resend.com → Domains → Add alasalicustomjewelry.ca → add DNS records in Cloudflare
#   3. Paste key below and add to Vercel environment variables
#
RESEND_API_KEY=
